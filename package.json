{
  "name": "@hb-kit/kiln",
  "version": "0.0.1",
  "type": "module",
  "description": "아이디어 한 줄을 브라우저에서 구워 개발 인계 패키지로 — PRD · 디자인(tokens + hi-fi) · handoff. 그 폴더를 당신이 이미 쓰는 코딩 에이전트(claude / codex)에 넘기면 개발이 시작된다.",
  "bin": {
    "kiln": "bin/kiln.js"
  },
  "files": [
    "bin/kiln.js",
    ".next/standalone",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dist": "next build && node build-dist.mjs",
    "prepack": "npm run dist",
    "ab": "node bin/ab.js",
    "ab:dry": "node bin/ab.js --variants echo,echo"
  },
  "//deps": "The published package is a self-contained standalone build — .next/standalone bundles its own traced node_modules, so runtime deps are devDependencies (build-time only). `npm i @hb-kit/kiln` pulls no extra tree.",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@google/genai": "^2.8.0",
    "@tanstack/react-query": "^5.62.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "next": "^15.1.3",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "zustand": "^5.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoonbeom1319/kiln.git"
  },
  "keywords": [
    "kiln",
    "claude-code",
    "codex",
    "prd",
    "design",
    "design-tokens",
    "hi-fi",
    "handoff",
    "nextjs",
    "local-first",
    "byo-agent",
    "idea-to-design",
    "cli"
  ],
  "author": "polaris (https://github.com/hoonbeom1319)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hoonbeom1319/kiln/issues"
  },
  "homepage": "https://github.com/hoonbeom1319/kiln#readme"
}
