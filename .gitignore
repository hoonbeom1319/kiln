node_modules/
.env
.env.local
*.log
.DS_Store

# Generated output at the repo root only — anchored so it never swallows source dirs like
# app/api/projects/ (an unanchored `projects/` matches that path too).
/runs/
/projects/*
# ...except committed showcase projects (example-*), which the gallery renders as demos.
!/projects/example-*/

# Next.js
.next/
next-env.d.ts
tsconfig.tsbuildinfo

# Playwright MCP output
.playwright-mcp/

# Render gate (shoot) output — regenerated per run, not source
projects/*/_shots/

# npm pack artifact
*.tgz
