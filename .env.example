# Copy to .env and fill in. Only the keys for providers you actually use are needed;
# the offline echo path (node bin/ab.js) needs none of these.

# --- provider keys ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- model id overrides (optional; defaults live in src/config.js MODELS) ---
# KILN_GEMINI_PRO=gemini-2.5-pro
# KILN_GEMINI_FLASH=gemini-2.5-flash
# KILN_OPUS=claude-opus-4-8
# KILN_SONNET=claude-sonnet-5
# KILN_HAIKU=claude-haiku-4-5-20251001

# --- generation defaults (optional) ---
# KILN_MAX_TOKENS=16000
# KILN_TEMPERATURE=0.7
# KILN_MAX_REPAIR=2

# Where the atelier repo lives, relative to this repo (source of the _fixture contract).
# KILN_ATELIER_DIR=../atelier
